# ============================================================
# Python 项目标准 .gitignore
# ============================================================

# --- Python 虚拟环境 ---
.venv/
venv/
env/
ENV/

# --- Python 编译缓存 ---
__pycache__/
*.py[cod]
*.pyo
*.pyd

# --- IDE / 编辑器 ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- 本地测试数据 & 缓存 ---
review_cache.json
result.json

# --- 业务报告导出 ---
*.xlsx

# --- 系统文件 ---
.DS_Store
Thumbs.db
desktop.ini
